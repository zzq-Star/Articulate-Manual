# ros2_control controller configuration
controller_manager:
  ros__parameters:
    update_rate: 100
    joint_state_broadcaster:
      type: joint_state_broadcaster/JointStateBroadcaster

    arm_controller:
      type: joint_trajectory_controller/JointTrajectoryController

arm_controller:
  ros__parameters:
    joints:
      {% for i in range(6) %}
      - joint_{{ i }}
      {% endfor %}

    command_joints:
      {% for i in range(6) %}
      - joint_{{ i }}
      {% endfor %}

    state_joints:
      {% for i in range(6) %}
      - joint_{{ i }}
      {% endfor %}

    state_publish_rate: 50.0
    action_monitor_rate: 20.0

    allow_partial_joints_goal: false
    open_loop_control: true

    constraints:
      stopped_velocity_tolerance: 0.01
      goal_time: 5.0

    gains:
      {% for i in range(6) %}
      joint_{{ i }}:
        p: 100.0
        i: 0.0
        d: 10.0
        i_clamp: 0.0
      {% endfor %}
